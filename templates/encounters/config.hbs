<div class="ccc-encounter-config-body">
  <p class="ccc-encounter-config-hint">{{localize "CCC.Encounter.Config.Intro"}}</p>

  <fieldset class="ccc-encounter-config-slot">
    <legend>{{localize "CCC.Encounter.Config.IntroTextLabel"}}</legend>
    <div class="form-group">
      <textarea name="introText" rows="6" class="ccc-encounter-config-textarea">{{introText}}</textarea>
      <p class="hint">{{localize "CCC.Encounter.Config.IntroTextHint"}}</p>
    </div>
  </fieldset>

  {{#each slots}}
    <fieldset class="ccc-encounter-config-slot" data-key="{{this.key}}">
      <legend>#{{this.idx}} — {{this.label}}</legend>

      <div class="form-group">
        <label>{{localize "CCC.Encounter.Config.Label"}}</label>
        <input type="text" name="slot.{{this.key}}.label" value="{{this.label}}" />
      </div>

      <div class="form-group">
        <label>{{localize "CCC.Encounter.Config.Actor"}}</label>
        <div class="drop-row">
          <input type="text" name="slot.{{this.key}}.actorUuid" value="{{this.actorUuid}}" data-drop="Actor" placeholder="Actor.xxxxxxxxxxxxxxxx" />
          <button type="button" data-action="clearField" data-target="slot.{{this.key}}.actorUuid" title="{{localize 'CCC.Encounter.Config.Clear'}}"><i class="fas fa-xmark"></i></button>
        </div>
      </div>

      <div class="form-group">
        <label>{{localize "CCC.Encounter.Config.Journal"}}</label>
        <div class="drop-row">
          <input type="text" name="slot.{{this.key}}.journalUuid" value="{{this.journalUuid}}" data-drop="JournalEntry" placeholder="JournalEntry.xxxxxxxxxxxxxxxx" />
          <button type="button" data-action="clearField" data-target="slot.{{this.key}}.journalUuid" title="{{localize 'CCC.Encounter.Config.Clear'}}"><i class="fas fa-xmark"></i></button>
        </div>
        <p class="hint">{{localize "CCC.Encounter.Config.JournalHint"}}</p>
      </div>

      <div class="form-group">
        <label>{{localize "CCC.Encounter.Config.Sounds"}}</label>
        <div class="ccc-encounter-config-sounds">
          {{#each this.sounds}}
            <div class="drop-row sound-row">
              <span class="outcome-tag">{{this.n}}</span>
              <input type="text" name="slot.{{../key}}.sound.{{this.i}}" value="{{this.value}}" data-drop="PlaylistSound" placeholder="PlaylistSound UUID" />
              <button type="button" data-action="previewSound" data-target="slot.{{../key}}.sound.{{this.i}}" title="{{localize 'CCC.Encounter.Config.Preview'}}"><i class="fas fa-play"></i></button>
              <button type="button" data-action="clearField" data-target="slot.{{../key}}.sound.{{this.i}}" title="{{localize 'CCC.Encounter.Config.Clear'}}"><i class="fas fa-xmark"></i></button>
            </div>
          {{/each}}
        </div>
      </div>
    </fieldset>
  {{/each}}
</div>
